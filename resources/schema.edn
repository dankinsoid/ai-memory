[;; Schema: nodes (facts) + edges (associations) + tags (flat atomic).

 ;; --- Tags (flat, no hierarchy) ---
 {:db/ident       :tag/name
  :db/valueType   :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique      :db.unique/identity
  :db/doc         "Atomic tag name, e.g. 'clj'. This is the tag identity."}

 {:db/ident       :tag/node-count
  :db/valueType   :db.type/long
  :db/cardinality :db.cardinality/one
  :db/doc         "Materialized count of nodes with this tag. Maintained by write pipeline."}

 {:db/ident       :tag/tier
  :db/valueType   :db.type/keyword
  :db/cardinality :db.cardinality/one
  :db/doc         "Tag tier: :aspect (fixed vocabulary). Nil for free-form tags (projects, technologies, domains)."}

 ;; --- Node (identified by :db/id) ---
 {:db/ident       :node/content
  :db/valueType   :db.type/string
  :db/cardinality :db.cardinality/one
  :db/fulltext    true
  :db/doc         "Node content — one thought, 1-3 sentences"}

 {:db/ident       :node/tag-refs
  :db/valueType   :db.type/ref
  :db/cardinality :db.cardinality/many
  :db/doc         "References to tag entities"}

 {:db/ident       :node/weight
  :db/valueType   :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc         "Base weight (before decay)"}

 {:db/ident       :node/cycle
  :db/valueType   :db.type/long
  :db/cardinality :db.cardinality/one
  :db/doc         "Last access/reinforcement cycle"}

 {:db/ident       :node/created-at
  :db/valueType   :db.type/instant
  :db/cardinality :db.cardinality/one
  :db/index       true
  :db/doc         "Creation timestamp (ms). Set once, never changes. Indexed for sorting."}

 {:db/ident       :node/updated-at
  :db/valueType   :db.type/instant
  :db/cardinality :db.cardinality/one
  :db/index       true
  :db/doc         "Last modification timestamp (ms). Updated on every write."}

 {:db/ident       :node/blob-dir
  :db/valueType   :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc         "Blob directory name under data/blobs/, e.g. '2026-02-17_blob-storage-design'"}

 {:db/ident       :node/sources
  :db/valueType   :db.type/string
  :db/cardinality :db.cardinality/many
  :db/doc         "Blob source refs. Format: 'dir-name/section-file'. Multiple sources allowed."}

 {:db/ident       :node/session-id
  :db/valueType   :db.type/string
  :db/cardinality :db.cardinality/one
  :db/index       true
  :db/doc         "Claude Code session ID. Links session facts and blobs to sessions."}

 ;; --- Edge ---
 {:db/ident       :edge/id
  :db/valueType   :db.type/uuid
  :db/cardinality :db.cardinality/one
  :db/unique      :db.unique/identity
  :db/doc         "Unique edge identifier"}

 {:db/ident       :edge/from
  :db/valueType   :db.type/ref
  :db/cardinality :db.cardinality/one
  :db/doc         "Source node"}

 {:db/ident       :edge/to
  :db/valueType   :db.type/ref
  :db/cardinality :db.cardinality/one
  :db/doc         "Target node"}

 {:db/ident       :edge/weight
  :db/valueType   :db.type/double
  :db/cardinality :db.cardinality/one
  :db/doc         "Edge weight (association strength)"}

 {:db/ident       :edge/cycle
  :db/valueType   :db.type/long
  :db/cardinality :db.cardinality/one
  :db/doc         "Last reinforcement cycle"}

 ;; --- Global tick ---
 {:db/ident       :tick/value
  :db/valueType   :db.type/long
  :db/cardinality :db.cardinality/one
  :db/doc         "Global monotonic tick counter"}

]
