;; Integrant system config, read via aero.
;; aero tags: #env VAR, #or [a b], #long "8080", #profile {:dev ... :prod ...}
{:config/env
 {:datomic-uri    #or [#env DATOMIC_URI "datomic:mem://ai-memory-dev"]
  :port           #long #or [#env PORT "8080"]
  :openai-api-key #env OPENAI_API_KEY
  :qdrant-url     #or [#env QDRANT_URL "http://localhost:6333"]
  :blob-path      #or [#env BLOB_PATH nil]
  :project-path   #env PROJECT_PATH
  :api-token      #env API_TOKEN
  ;; :memory — in-memory stores (no external deps), :qdrant — real Qdrant
  :vector-backend #profile {:dev :memory :default :qdrant}
  ;; :random — deterministic pseudo-random vectors (no API key needed), :openai — real OpenAI
  ;; dev: auto-detects — uses :openai if OPENAI_API_KEY is set, :random otherwise
  :embedding-backend #profile {:dev :auto :default :openai}}

 :metrics/registry {}

 :db/conn
 {:cfg #ig/ref :config/env}

 :store/fact
 {:conn #ig/ref :db/conn}

 :store/embedding
 {:cfg #ig/ref :config/env}

 :store/vectors
 {:cfg        #ig/ref :config/env
  :embedding  #ig/ref :store/embedding
  :collection "nodes"}

 :store/tag-vectors
 {:cfg        #ig/ref :config/env
  :embedding  #ig/ref :store/embedding
  :collection "tags"}

 ;; Unified context for all services: stores + config values they need.
 ;; Service functions receive this as first arg instead of separate stores/cfg/metrics.
 :service/context
 {:fact-store       #ig/ref :store/fact
  :vector-store     #ig/ref :store/vectors
  :tag-vector-store #ig/ref :store/tag-vectors
  :embedding        #ig/ref :store/embedding
  :metrics          #ig/ref :metrics/registry
  :cfg              #ig/ref :config/env}

 :service/seed
 {:ctx #ig/ref :service/context}

 :web/server
 {:ctx  #ig/ref :service/context
  :conn #ig/ref :db/conn
  :cfg  #ig/ref :config/env}

 :scheduler/reconcile
 {:fact-store #ig/ref :store/fact}}
