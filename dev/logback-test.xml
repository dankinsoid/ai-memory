<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%msg%n</pattern>
    </encoder>
  </appender>
  <root level="ERROR">
    <appender-ref ref="STDOUT"/>
  </root>
  <!-- Наш код — INFO, всё остальное — тишина -->
  <logger name="ai-memory" level="INFO"/>
</configuration>
