{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    { "title": "Overview", "url": "/d/overview", "type": "link" },
    { "title": "Read Pipeline", "url": "/d/read-pipeline", "type": "link" }
  ],
  "panels": [
    {
      "title": "Write Duration by Phase (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(memory_write_duration_seconds_bucket[5m])) by (le, phase))",
          "legendFormat": "{{phase}}"
        }
      ]
    },
    {
      "title": "Edge Creation Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(memory_write_edges_total[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "title": "Edges per Call (avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(memory_write_edges_sum[5m])) by (type) / sum(rate(memory_write_edges_count[5m])) by (type)",
          "legendFormat": "avg {{type}}"
        }
      ]
    },
    {
      "title": "DB Operations Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(memory_write_db_ops_total[5m])",
          "legendFormat": "db ops/s"
        }
      ]
    },
    {
      "title": "Batch Size Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 80 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(memory_write_batch_size_bucket[1h])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    },
    {
      "title": "Nodes: Created vs Reinforced",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(memory_write_nodes_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Context Cache Size",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "memory_context_cache_size",
          "legendFormat": "active contexts"
        }
      ]
    },
    {
      "title": "Total Edges (cumulative)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 100000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(memory_write_edges_total) by (type)",
          "legendFormat": "{{type}}"
        }
      ],
      "options": {
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ai-memory", "write-pipeline"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Write Pipeline",
  "uid": "write-pipeline"
}
