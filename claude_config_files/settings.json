{
  "permissions": {
    "allow": [
      "mcp__ai-memory__memory_explore_tags",
      "mcp__ai-memory__memory_get_facts",
      "mcp__ai-memory__memory_remember",
      "mcp__ai-memory__memory_store_file",
      "mcp__ai-memory__memory_read_blob",
      "mcp__ai-memory__memory_create_tag",
      "mcp__ai-memory__memory_list_blobs",
      "mcp__ai-memory__memory_reinforce",
      "mcp__ai-memory__memory_session"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bb ~/.claude/hooks/session-reminder.bb",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bb ~/.claude/hooks/memory-nudge.bb",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bb ~/.claude/hooks/session-sync.bb",
            "timeout": 30000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "bb ~/.claude/hooks/session-end.bb",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bb ~/.claude/hooks/session-start.bb",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
