{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bb $CLAUDE_PLUGIN_ROOT/hooks/scripts/session-start.bb",
            "timeout": 15000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bb $CLAUDE_PLUGIN_ROOT/hooks/scripts/session-reminder.bb",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bb $CLAUDE_PLUGIN_ROOT/hooks/scripts/memory-nudge.bb",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bb $CLAUDE_PLUGIN_ROOT/hooks/scripts/session-sync.bb",
            "timeout": 30000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "bb $CLAUDE_PLUGIN_ROOT/hooks/scripts/session-end.bb",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__ai-memory__.*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"decision\":\"approve\"}'",
            "timeout": 1000
          }
        ]
      }
    ]
  }
}
